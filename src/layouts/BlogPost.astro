---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, updatedDate, author, tags, coverImage } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} ogImage={coverImage}>
  <article class="mx-auto max-w-3xl px-5 py-12 sm:py-16">
    <!-- Back link -->
    <a
      href="/blogs"
      class="inline-flex items-center gap-2 text-sm text-white/45 hover:text-white transition-colors mb-8 group"
    >
      <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      All Posts
    </a>

    <!-- Header -->
    <header class="mb-10">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag) => (
            <span class="font-mono text-[11px] uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-violet/10 text-violet border border-violet/20">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white leading-tight mb-4">
        {title}
      </h1>

      <p class="text-lg text-white/50 leading-relaxed mb-6">
        {description}
      </p>

      <div class="flex items-center gap-4 text-sm text-white/40">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-full bg-gradient-brand flex items-center justify-center">
            <span class="text-[#08080f] font-bold text-[10px]">{author?.charAt(0) || 'P'}</span>
          </div>
          <span>{author}</span>
        </div>
        <span class="text-white/20">&middot;</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {updatedDate && (
          <>
            <span class="text-white/20">&middot;</span>
            <span class="text-white/30">Updated {formattedUpdate}</span>
          </>
        )}
      </div>
    </header>

    <!-- Cover image -->
    {coverImage && (
      <div class="rounded-2xl overflow-hidden border border-white/[0.08] mb-10">
        <img src={coverImage} alt={title} class="w-full" />
      </div>
    )}

    <!-- Divider -->
    <div class="h-px bg-white/[0.08] mb-10"></div>

    <!-- Content -->
    <div class="prose-blog">
      <slot />
    </div>

    <!-- Footer divider -->
    <div class="h-px bg-white/[0.08] mt-12 mb-8"></div>

    <!-- CTA -->
    <div class="rounded-2xl border border-white/[0.08] bg-white/[0.02] p-6 sm:p-8 text-center">
      <h3 class="font-display text-xl font-semibold text-white mb-2">
        Ready to level up your trading?
      </h3>
      <p class="text-sm text-white/50 mb-5 max-w-md mx-auto">
        Start your AI-powered trading journal today. Track trades, understand your psychology, and get personalized coaching.
      </p>
      <a
        href="https://proplogai.com/login"
        class="inline-flex px-6 py-2.5 rounded-xl bg-gradient-brand text-[#08080f] text-sm font-semibold hover:opacity-90 transition-opacity"
      >
        Get Started Free
      </a>
    </div>
  </article>
</BaseLayout>
