---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, updatedDate, author, tags, coverImage } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} ogImage={coverImage}>
  <article class="mx-auto max-w-3xl px-5 py-12 sm:py-16">
    <!-- Back link -->
    <a
      href="/blogs"
      class="inline-flex items-center gap-2 text-sm text-white/35 hover:text-white transition-all duration-300 mb-10 group"
    >
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      <span>All Posts</span>
    </a>

    <!-- Header -->
    <header class="mb-10 animate-fade-in-up">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5">
          {tags.map((tag) => (
            <span class="font-mono text-[10px] uppercase tracking-widest px-2.5 py-1 rounded-full bg-violet/[0.08] text-violet/90 border border-violet/[0.12]">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="font-display text-3xl sm:text-4xl lg:text-[2.75rem] font-bold text-white leading-tight mb-5 tracking-tight">
        {title}
      </h1>

      <p class="text-lg text-white/45 leading-relaxed mb-7">
        {description}
      </p>

      <div class="flex items-center gap-4 text-sm text-white/35">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-full bg-gradient-brand flex items-center justify-center shadow-lg shadow-violet/20">
            <span class="text-[#08080f] font-bold text-xs">{author?.charAt(0) || 'P'}</span>
          </div>
          <div>
            <span class="block text-white/60 font-medium text-sm">{author}</span>
            <div class="flex items-center gap-2 text-xs text-white/30">
              <time datetime={date.toISOString()}>{formattedDate}</time>
              {updatedDate && (
                <>
                  <span class="text-white/15">&middot;</span>
                  <span>Updated {formattedUpdate}</span>
                </>
              )}
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Cover image -->
    {coverImage && (
      <div class="rounded-2xl overflow-hidden border border-white/[0.06] mb-12 animate-fade-in-up stagger-1 shadow-2xl shadow-black/30">
        <img src={coverImage} alt={title} class="w-full" />
      </div>
    )}

    <!-- Divider -->
    <div class="gradient-divider mb-10"></div>

    <!-- Content -->
    <div class="prose-blog animate-fade-in-up stagger-2">
      <slot />
    </div>

    <!-- Footer -->
    <div class="gradient-divider mt-14 mb-10"></div>

    <!-- CTA -->
    <div class="relative rounded-2xl overflow-hidden animate-fade-in-up stagger-3">
      <div class="absolute inset-0 bg-gradient-to-r from-violet/15 via-cyan/15 to-violet/15 rounded-2xl"></div>
      <div class="relative m-[1px] rounded-2xl bg-[#0b0b14] p-7 sm:p-9 text-center">
        <h3 class="font-display text-xl sm:text-2xl font-bold text-white mb-2.5 tracking-tight">
          Ready to level up your trading?
        </h3>
        <p class="text-sm text-white/40 mb-6 max-w-md mx-auto leading-relaxed">
          Start your AI-powered trading journal today. Track trades, understand your psychology, and get personalized coaching from Propol AI.
        </p>
        <a
          href="https://proplogai.com/login"
          class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-gradient-brand text-[#08080f] text-sm font-semibold hover:shadow-lg hover:shadow-violet/25 transition-all duration-300 hover:-translate-y-0.5"
        >
          Get Started Free
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
