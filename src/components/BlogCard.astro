---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
  coverImage?: string;
  author?: string;
}

const { title, description, date, slug, tags = [], coverImage, author = 'PropLogAI Team' } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blogs/${slug}`} class="group block">
  <article class="card-premium overflow-hidden h-full flex flex-col">
    {coverImage && (
      <div class="aspect-[16/9] overflow-hidden relative">
        <img
          src={coverImage}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#07070b] via-transparent to-transparent opacity-60"></div>
      </div>
    )}

    <div class="p-5 sm:p-6 flex-1 flex flex-col">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-3">
          {tags.slice(0, 3).map((tag) => (
            <span class="font-mono text-[10px] uppercase tracking-widest px-2.5 py-1 rounded-full bg-violet/[0.08] text-violet/90 border border-violet/[0.12]">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h2 class="font-display font-semibold text-lg text-white mb-2.5 leading-snug group-hover:text-violet transition-colors duration-300 line-clamp-2">
        {title}
      </h2>

      <p class="text-sm text-white/45 mb-5 line-clamp-2 leading-relaxed flex-1">
        {description}
      </p>

      <div class="flex items-center justify-between text-[11px] text-white/30 pt-4 border-t border-white/[0.04]">
        <div class="flex items-center gap-2">
          <div class="w-5 h-5 rounded-full bg-gradient-brand flex items-center justify-center flex-shrink-0">
            <span class="text-[#08080f] font-bold text-[8px]">{author?.charAt(0) || 'P'}</span>
          </div>
          <span class="font-medium text-white/40">{author}</span>
        </div>
        <time datetime={date.toISOString()} class="font-mono tracking-wider">{formattedDate}</time>
      </div>
    </div>
  </article>
</a>
