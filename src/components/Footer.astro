---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/[0.06] mt-24">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <a href="https://proplogai.com" class="flex items-center gap-2.5 mb-4">
          <div class="w-7 h-7 rounded-lg bg-gradient-brand flex items-center justify-center">
            <span class="text-[#08080f] font-bold text-xs">P</span>
          </div>
          <span class="font-display font-semibold text-white">
            PropLog<span class="bg-gradient-brand bg-clip-text text-transparent">AI</span>
          </span>
        </a>
        <p class="text-sm text-white/45 leading-relaxed max-w-xs">
          AI-powered trading journal for prop firm traders. Log trades, track emotions, and get personalized coaching.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="font-mono text-xs uppercase tracking-wider text-white/55 mb-4">Product</h4>
        <ul class="space-y-2.5">
          <li><a href="https://proplogai.com/#features" class="text-sm text-white/50 hover:text-white transition-colors">Features</a></li>
          <li><a href="https://proplogai.com/#pricing" class="text-sm text-white/50 hover:text-white transition-colors">Pricing</a></li>
          <li><a href="/blogs" class="text-sm text-white/50 hover:text-white transition-colors">Blog</a></li>
          <li><a href="https://proplogai.com/login" class="text-sm text-white/50 hover:text-white transition-colors">Login</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-mono text-xs uppercase tracking-wider text-white/55 mb-4">Legal</h4>
        <ul class="space-y-2.5">
          <li><a href="https://proplogai.com/privacy" class="text-sm text-white/50 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="https://proplogai.com/terms" class="text-sm text-white/50 hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/30">
        &copy; {year} PropLogAI. All rights reserved.
      </p>
      <p class="text-xs text-white/25">
        PropLogAI does not provide financial or investment advice.
      </p>
    </div>
  </div>
</footer>
