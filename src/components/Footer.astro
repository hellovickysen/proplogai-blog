---
const year = new Date().getFullYear();
---

<footer class="mt-24">
  <div class="gradient-divider"></div>
  <div class="mx-auto max-w-6xl px-5 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <a href="https://proplogai.com" class="flex items-center gap-2.5 mb-4 group">
          <span class="grid flex-shrink-0 place-items-center rounded-lg" style="width:28px;height:28px;background:linear-gradient(135deg,#a78bfa,#22d3ee);">
            <svg width="28" height="28" viewBox="0 0 100 100" aria-hidden="true">
              <polygon points="22,42 50,49 50,75 22,69" fill="#08080f" />
              <polygon points="78,42 50,49 50,75 78,69" fill="#08080f" />
              <polyline points="50,49 63,39 74,27" fill="none" stroke="#08080f" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round" />
              <circle cx="74" cy="27" r="4.5" fill="#08080f" />
            </svg>
          </span>
          <span class="font-display font-bold text-white tracking-tight">
            PropLog<span class="gradient-text">AI</span>
          </span>
        </a>
        <p class="text-sm text-white/35 leading-relaxed max-w-xs">
          AI-powered trading journal for prop firm traders. Log trades, track emotions, and get personalized coaching from Propol AI.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/40 mb-5">Product</h4>
        <ul class="space-y-3">
          <li><a href="https://proplogai.com/#features" class="text-sm text-white/40 hover:text-white transition-colors duration-300">Features</a></li>
          <li><a href="https://proplogai.com/#pricing" class="text-sm text-white/40 hover:text-white transition-colors duration-300">Pricing</a></li>
          <li><a href="/blogs" class="text-sm text-white/40 hover:text-white transition-colors duration-300">Blog</a></li>
          <li><a href="https://proplogai.com/login" class="text-sm text-white/40 hover:text-white transition-colors duration-300">Login</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/40 mb-5">Legal</h4>
        <ul class="space-y-3">
          <li><a href="https://proplogai.com/privacy" class="text-sm text-white/40 hover:text-white transition-colors duration-300">Privacy Policy</a></li>
          <li><a href="https://proplogai.com/terms" class="text-sm text-white/40 hover:text-white transition-colors duration-300">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/[0.04] flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/25">
        &copy; {year} PropLogAI. All rights reserved.
      </p>
      <p class="text-xs text-white/20">
        PropLogAI does not provide financial or investment advice.
      </p>
    </div>
  </div>
</footer>
