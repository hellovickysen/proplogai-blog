---
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/[0.06] bg-surface/80 backdrop-blur-xl">
  <div class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="https://proplogai.com" class="flex items-center gap-2.5 group">
      <div class="w-8 h-8 rounded-lg bg-gradient-brand flex items-center justify-center">
        <span class="text-[#08080f] font-bold text-sm">P</span>
      </div>
      <span class="font-display font-semibold text-white text-lg">
        PropLog<span class="bg-gradient-brand bg-clip-text text-transparent">AI</span>
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-1">
      <a href="https://proplogai.com" class="px-4 py-2 rounded-lg text-sm text-white/60 hover:text-white hover:bg-white/[0.04] transition-all">
        Home
      </a>
      <a href="/blogs" class="px-4 py-2 rounded-lg text-sm text-white hover:bg-white/[0.04] transition-all font-medium bg-white/[0.06]">
        Blog
      </a>
      <a href="https://proplogai.com/#features" class="px-4 py-2 rounded-lg text-sm text-white/60 hover:text-white hover:bg-white/[0.04] transition-all">
        Features
      </a>
      <a href="https://proplogai.com/#pricing" class="px-4 py-2 rounded-lg text-sm text-white/60 hover:text-white hover:bg-white/[0.04] transition-all">
        Pricing
      </a>
    </nav>

    <!-- CTA + Mobile -->
    <div class="flex items-center gap-3">
      <a
        href="https://proplogai.com/login"
        class="hidden sm:inline-flex px-5 py-2 rounded-xl bg-gradient-brand text-[#08080f] text-sm font-semibold hover:opacity-90 transition-opacity"
      >
        Start Trading Journal
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-white/60 hover:text-white hover:bg-white/[0.06] transition-all"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/[0.06] bg-surface/95 backdrop-blur-xl">
    <div class="px-5 py-4 flex flex-col gap-1">
      <a href="https://proplogai.com" class="px-4 py-2.5 rounded-lg text-sm text-white/60 hover:text-white hover:bg-white/[0.04] transition-all">
        Home
      </a>
      <a href="/blogs" class="px-4 py-2.5 rounded-lg text-sm text-white font-medium bg-white/[0.06]">
        Blog
      </a>
      <a href="https://proplogai.com/#features" class="px-4 py-2.5 rounded-lg text-sm text-white/60 hover:text-white hover:bg-white/[0.04] transition-all">
        Features
      </a>
      <a href="https://proplogai.com/#pricing" class="px-4 py-2.5 rounded-lg text-sm text-white/60 hover:text-white hover:bg-white/[0.04] transition-all">
        Pricing
      </a>
      <a
        href="https://proplogai.com/login"
        class="mt-2 px-5 py-2.5 rounded-xl bg-gradient-brand text-[#08080f] text-sm font-semibold text-center hover:opacity-90 transition-opacity"
      >
        Start Trading Journal
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    if (isOpen) {
      icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    } else {
      icon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  });
</script>
