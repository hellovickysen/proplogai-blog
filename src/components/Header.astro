---
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#07070b]/70 backdrop-blur-2xl backdrop-saturate-150">
  <div class="gradient-divider"></div>
  <div class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between">
    <!-- Logo (matches PropLogAI Open Journal mark) -->
    <a href="https://proplogai.com" class="flex items-center gap-2.5 group">
      <span class="grid flex-shrink-0 place-items-center rounded-lg" style="width:32px;height:32px;background:linear-gradient(135deg,#a78bfa,#22d3ee);box-shadow:0 0 18px rgba(139,92,246,0.5);">
        <svg width="32" height="32" viewBox="0 0 100 100" aria-hidden="true">
          <polygon points="22,42 50,49 50,75 22,69" fill="#08080f" />
          <polygon points="78,42 50,49 50,75 78,69" fill="#08080f" />
          <polyline points="50,49 63,39 74,27" fill="none" stroke="#08080f" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="74" cy="27" r="4.5" fill="#08080f" />
        </svg>
      </span>
      <span class="font-display font-bold text-white text-lg tracking-tight">
        PropLog<span class="gradient-text">AI</span>
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-1">
      <a href="https://proplogai.com" class="px-4 py-2 rounded-lg text-sm text-white/50 hover:text-white transition-all duration-300">
        Home
      </a>
      <a href="/blogs" class="px-4 py-2 rounded-lg text-sm text-white font-medium bg-white/[0.06] border border-white/[0.06]">
        Blog
      </a>
      <a href="https://proplogai.com/#features" class="px-4 py-2 rounded-lg text-sm text-white/50 hover:text-white transition-all duration-300">
        Features
      </a>
      <a href="https://proplogai.com/#pricing" class="px-4 py-2 rounded-lg text-sm text-white/50 hover:text-white transition-all duration-300">
        Pricing
      </a>
    </nav>

    <!-- CTA + Mobile -->
    <div class="flex items-center gap-3">
      <a
        href="https://proplogai.com/login"
        class="hidden sm:inline-flex px-5 py-2 rounded-xl bg-gradient-brand text-[#08080f] text-sm font-semibold hover:shadow-lg hover:shadow-violet/25 transition-all duration-300 hover:-translate-y-0.5"
      >
        Start Trading Journal
      </a>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-white/50 hover:text-white hover:bg-white/[0.06] transition-all"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/[0.04] bg-[#07070b]/95 backdrop-blur-2xl">
    <div class="px-5 py-4 flex flex-col gap-1">
      <a href="https://proplogai.com" class="px-4 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/[0.04] transition-all">
        Home
      </a>
      <a href="/blogs" class="px-4 py-2.5 rounded-lg text-sm text-white font-medium bg-white/[0.06]">
        Blog
      </a>
      <a href="https://proplogai.com/#features" class="px-4 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/[0.04] transition-all">
        Features
      </a>
      <a href="https://proplogai.com/#pricing" class="px-4 py-2.5 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/[0.04] transition-all">
        Pricing
      </a>
      <a
        href="https://proplogai.com/login"
        class="mt-2 px-5 py-2.5 rounded-xl bg-gradient-brand text-[#08080f] text-sm font-semibold text-center"
      >
        Start Trading Journal
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    if (isOpen) {
      icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    } else {
      icon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  });
</script>
