---
import { getCollection } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return posts.map((post) => {
    const relatedPosts = posts
      .filter((candidate) => candidate.slug !== post.slug)
      .map((candidate) => {
        const sameCategory = candidate.data.category === post.data.category ? 2 : 0;
        const sameSilo = candidate.data.silo === post.data.silo ? 1 : 0;
        const relevance = sameCategory + sameSilo;
        return { post: candidate, relevance };
      })
      .sort((a, b) => {
        if (b.relevance !== a.relevance) return b.relevance - a.relevance;
        return b.post.data.date.valueOf() - a.post.data.date.valueOf();
      })
      .slice(0, 3)
      .map(({ post }) => post);

    return {
      params: { slug: post.slug },
      props: { post, relatedPosts },
    };
  });
}

const { post, relatedPosts } = Astro.props;
const { Content } = await post.render();
---

<BlogPost post={post} relatedPosts={relatedPosts}>
  <Content />
</BlogPost>
