---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allCategories = [...new Set(posts.map((p) => p.data.category))].sort();

const featuredPost = posts[0];
const restPosts = posts.slice(1);
---

<BaseLayout title="Blog">
  <!-- Hero Section -->
  <section class="mx-auto max-w-6xl px-5 pt-16 sm:pt-20 pb-6">
    <div class="animate-fade-in-up">
      <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-violet mb-4">Blog</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white tracking-tight mb-3">
        Insights & Resources
      </h1>
      <p class="text-base text-white/40 max-w-xl leading-relaxed">
        Trading psychology, discipline, journaling, and prop firm systems — organized by content silo.
      </p>
    </div>
  </section>

  <!-- Filter Bar -->
  <section class="relative z-20 mx-auto max-w-6xl px-5 pb-8 animate-fade-in-up stagger-1">
    <div class="flex items-start gap-3 border-b border-white/[0.06] pb-5">
      <div class="relative w-full sm:w-56">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-white/20 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="blog-search"
          placeholder="Search..."
          class="w-full pl-9 pr-3 py-2 rounded-lg bg-transparent border border-white/[0.06] text-sm text-white placeholder-white/20 focus:outline-none focus:border-violet/30 transition-all duration-300"
        />
      </div>

      <div class="relative" id="category-dropdown-wrapper">
        <button
          id="category-dropdown-btn"
          class="flex items-center gap-2 px-3 py-2 rounded-lg border border-white/[0.06] text-sm text-white/40 hover:border-violet/30 hover:text-white/60 transition-all duration-300 cursor-pointer"
        >
          <span id="category-dropdown-label">All Categories</span>
          <svg class="w-3 h-3 text-white/20 transition-transform duration-200" id="category-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div id="category-dropdown-menu" class="hidden absolute top-full left-0 mt-1.5 w-64 rounded-xl bg-[#12121a] border border-white/[0.08] shadow-2xl shadow-black/50 overflow-hidden z-50">
          <div class="py-1">
            <button data-category="all" class="category-option active w-full text-left px-4 py-2 text-sm transition-colors duration-200">All Categories</button>
            {allCategories.map((category) => (
              <button data-category={category} class="category-option w-full text-left px-4 py-2 text-sm transition-colors duration-200">{category}</button>
            ))}
          </div>
        </div>
      </div>

      <p id="result-count" class="text-[11px] text-white/20 font-mono ml-auto">
        {posts.length} articles
      </p>
    </div>
  </section>

  <!-- Featured Post -->
  {featuredPost && (
    <section class="mx-auto max-w-6xl px-5 pb-12 animate-fade-in-up stagger-2" id="featured-hero">
      <a href={`/blogs/${featuredPost.slug}`} class="group block">
        <article class="rounded-2xl border border-white/[0.06] bg-white/[0.015] overflow-hidden hover:border-white/[0.12] transition-all duration-500">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            {featuredPost.data.coverImage && (
              <div class="aspect-[16/10] lg:aspect-auto overflow-hidden">
                <img
                  src={featuredPost.data.coverImage}
                  alt={featuredPost.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-700 ease-out"
                />
              </div>
            )}

            <div class="p-7 sm:p-9 flex flex-col justify-center">
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-violet font-medium mb-4">
                {featuredPost.data.category}
              </p>

              <h2 class="font-display text-xl sm:text-2xl font-bold text-white leading-snug mb-3 group-hover:text-violet/90 transition-colors duration-300">
                {featuredPost.data.title}
              </h2>

              <p class="text-sm text-white/40 leading-relaxed mb-6 line-clamp-3">
                {featuredPost.data.description}
              </p>

              <span class="flex items-center gap-1.5 text-xs text-violet/70 font-medium group-hover:text-violet transition-colors duration-300">
                Read article
                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </span>
            </div>
          </div>
        </article>
      </a>
    </section>
  )}

  <!-- Rest of posts grid -->
  <section class="mx-auto max-w-6xl px-5 pb-20">
    {restPosts.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="posts-grid">
        {restPosts.map((post, i) => (
          <div
            class={`blog-post-item animate-fade-in-up stagger-${Math.min(i + 1, 4)}`}
            data-category={post.data.category}
            data-silo={post.data.silo}
            data-title={post.data.title.toLowerCase()}
            data-description={post.data.description.toLowerCase()}
          >
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.slug}
              category={post.data.category}
              coverImage={post.data.coverImage}
            />
          </div>
        ))}
      </div>
    )}

    {featuredPost && (
      <div
        class="blog-post-item"
        data-category={featuredPost.data.category}
        data-silo={featuredPost.data.silo}
        data-title={featuredPost.data.title.toLowerCase()}
        data-description={featuredPost.data.description.toLowerCase()}
        data-is-featured="true"
        style="display:none;"
      ></div>
    )}

    <div id="no-results" class="hidden text-center py-16">
      <p class="text-white/30 text-sm">No posts found</p>
      <p class="text-white/15 text-xs mt-1">Try a different search or category</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-5 pb-20">
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.015] p-8 sm:p-12 text-center">
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-white mb-3 tracking-tight">
        Start your trading journal
      </h2>
      <p class="text-sm text-white/40 mb-7 max-w-lg mx-auto leading-relaxed">
        Track trades, understand your psychology, and get personalized coaching from Propol AI.
      </p>
      <a
        href="https://proplogai.com/login"
        class="inline-flex items-center gap-2 px-7 py-3 rounded-xl bg-gradient-brand text-[#08080f] text-sm font-semibold hover:shadow-lg hover:shadow-violet/25 transition-all duration-300 hover:-translate-y-0.5"
      >
        Get Started Free
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .category-option { color: rgba(255, 255, 255, 0.4); }
  .category-option:hover { background: rgba(167, 139, 250, 0.06); color: rgba(255, 255, 255, 0.7); }
  .category-option.active { background: rgba(167, 139, 250, 0.1); color: #a78bfa; }
  .blog-post-item.hidden-by-filter { display: none; }
</style>

<script>
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  const dropdownBtn = document.getElementById('category-dropdown-btn');
  const dropdownMenu = document.getElementById('category-dropdown-menu');
  const dropdownLabel = document.getElementById('category-dropdown-label');
  const chevron = document.getElementById('category-chevron');
  const categoryOptions = document.querySelectorAll('.category-option');
  const postItems = document.querySelectorAll('.blog-post-item');
  const resultCount = document.getElementById('result-count');
  const noResults = document.getElementById('no-results');
  const postsGrid = document.getElementById('posts-grid');

  let activeCategory = 'all';
  let searchQuery = '';
  let menuOpen = false;

  function toggleMenu(open?: boolean) {
    menuOpen = open !== undefined ? open : !menuOpen;
    dropdownMenu?.classList.toggle('hidden', !menuOpen);
    chevron?.classList.toggle('rotate-180', menuOpen);
  }

  dropdownBtn?.addEventListener('click', (e) => { e.stopPropagation(); toggleMenu(); });
  document.addEventListener('click', () => toggleMenu(false));
  dropdownMenu?.addEventListener('click', (e) => e.stopPropagation());

  function filterPosts() {
    let visible = 0;
    const isFiltering = activeCategory !== 'all' || searchQuery !== '';

    postItems.forEach((item) => {
      const el = item as HTMLElement;
      const category = el.dataset.category || '';
      const silo = el.dataset.silo || '';
      const title = el.dataset.title || '';
      const desc = el.dataset.description || '';
      const isFeatured = el.dataset.isFeatured === 'true';

      const matchesCategory = activeCategory === 'all' || category === activeCategory;
      const matchesSearch = !searchQuery || title.includes(searchQuery) || desc.includes(searchQuery) || category.toLowerCase().includes(searchQuery) || silo.toLowerCase().includes(searchQuery);

      if (matchesCategory && matchesSearch) {
        if (!isFeatured) el.classList.remove('hidden-by-filter');
        visible++;
      } else {
        if (!isFeatured) el.classList.add('hidden-by-filter');
      }
    });

    const heroSection = document.getElementById('featured-hero');
    if (heroSection) heroSection.style.display = isFiltering ? 'none' : '';

    if (resultCount) resultCount.textContent = `${visible} article${visible !== 1 ? 's' : ''}`;
    if (noResults) noResults.classList.toggle('hidden', visible > 0);
    if (postsGrid) postsGrid.classList.toggle('hidden', visible === 0);
  }

  categoryOptions.forEach((opt) => {
    opt.addEventListener('click', () => {
      categoryOptions.forEach((o) => o.classList.remove('active'));
      opt.classList.add('active');
      activeCategory = (opt as HTMLElement).dataset.category || 'all';
      if (dropdownLabel) dropdownLabel.textContent = activeCategory === 'all' ? 'All Categories' : activeCategory;
      toggleMenu(false);
      filterPosts();
    });
  });

  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    filterPosts();
  });
</script>
