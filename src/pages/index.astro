---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Extract unique tags
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Blog">
  <!-- Hero -->
  <section class="relative mx-auto max-w-6xl px-5 pt-16 sm:pt-24 pb-10 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-gradient-to-b from-violet/[0.07] via-cyan/[0.04] to-transparent rounded-full blur-3xl pointer-events-none" style="animation: pulse-glow 6s ease-in-out infinite;"></div>

    <div class="relative max-w-2xl animate-fade-in-up">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.04] border border-white/[0.06] mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-profit animate-pulse"></span>
        <span class="font-mono text-[11px] uppercase tracking-widest text-white/45">PropLogAI Blog</span>
      </div>

      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-5 tracking-tight leading-[1.1]">
        Trading <span class="gradient-text">Insights</span>
      </h1>

      <p class="text-lg sm:text-xl text-white/45 leading-relaxed max-w-xl">
        Psychology, discipline, and performance — everything you need to become a consistently profitable trader.
      </p>
    </div>
  </section>

  <!-- Search + Filter Bar (left-aligned) -->
  <section class="mx-auto max-w-6xl px-5 pb-8 animate-fade-in-up stagger-1">
    <div class="flex items-center gap-3 flex-wrap">
      <!-- Search -->
      <div class="relative w-full sm:w-64">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-white/25 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="blog-search"
          placeholder="Search posts..."
          class="w-full pl-10 pr-4 py-2.5 rounded-xl bg-white/[0.03] border border-white/[0.06] text-sm text-white placeholder-white/25 focus:outline-none focus:border-violet/30 focus:bg-white/[0.05] transition-all duration-300"
        />
      </div>

      <!-- Tag Dropdown -->
      <div class="relative" id="tag-dropdown-wrapper">
        <button
          id="tag-dropdown-btn"
          class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/[0.03] border border-white/[0.06] text-sm text-white/50 hover:border-violet/30 hover:text-white/70 transition-all duration-300 cursor-pointer min-w-[140px]"
        >
          <svg class="w-4 h-4 text-white/30 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
          <span id="tag-dropdown-label" class="flex-1 text-left">All Topics</span>
          <svg class="w-3.5 h-3.5 text-white/25 flex-shrink-0 transition-transform duration-200" id="tag-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Dropdown menu -->
        <div id="tag-dropdown-menu" class="hidden absolute top-full left-0 mt-2 w-52 rounded-xl bg-[#12121a] border border-white/[0.08] shadow-2xl shadow-black/50 overflow-hidden z-50">
          <div class="py-1.5">
            <button data-tag="all" class="tag-option active w-full text-left px-4 py-2 text-sm transition-colors duration-200">
              All Topics
            </button>
            {allTags.map((tag) => (
              <button data-tag={tag} class="tag-option w-full text-left px-4 py-2 text-sm transition-colors duration-200 capitalize">
                {tag}
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Result count -->
      <p id="result-count" class="text-xs text-white/25 font-mono ml-1">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'}
      </p>

      <!-- Clear -->
      <button
        id="clear-filters"
        class="hidden text-xs text-violet/70 hover:text-violet transition-colors duration-300 font-medium ml-auto"
      >
        Clear filters
      </button>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="mx-auto max-w-6xl px-5 pb-20">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-7" id="posts-grid">
        {posts.map((post, i) => (
          <div
            class={`blog-post-item animate-fade-in-up stagger-${Math.min(i + 1, 4)}`}
            data-tags={post.data.tags.join(',')}
            data-title={post.data.title.toLowerCase()}
            data-description={post.data.description.toLowerCase()}
          >
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.slug}
              tags={post.data.tags}
              coverImage={post.data.coverImage}
              author={post.data.author}
            />
          </div>
        ))}
      </div>

      <!-- No results -->
      <div id="no-results" class="hidden text-center py-16">
        <div class="w-14 h-14 mx-auto mb-4 rounded-2xl bg-white/[0.03] border border-white/[0.06] flex items-center justify-center">
          <svg class="w-6 h-6 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <p class="text-white/35 text-sm mb-1">No posts found</p>
        <p class="text-white/20 text-xs">Try a different search or topic</p>
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-white/[0.03] border border-white/[0.06] flex items-center justify-center">
          <svg class="w-7 h-7 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <p class="text-white/35 text-sm">No posts yet. Check back soon!</p>
      </div>
    )}
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-5 pb-20">
    <div class="relative rounded-2xl overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-violet/20 via-cyan/20 to-violet/20 rounded-2xl"></div>
      <div class="relative m-[1px] rounded-2xl bg-[#0b0b14] p-8 sm:p-12 text-center">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[300px] h-[200px] bg-gradient-to-b from-violet/[0.06] to-transparent rounded-full blur-3xl pointer-events-none"></div>

        <h2 class="relative font-display text-2xl sm:text-3xl font-bold text-white mb-3 tracking-tight">
          Ready to trade <span class="gradient-text">smarter</span>?
        </h2>
        <p class="relative text-sm sm:text-base text-white/45 mb-7 max-w-lg mx-auto leading-relaxed">
          Start your AI-powered trading journal. Track emotions, identify patterns, and get personalized coaching from Propol AI.
        </p>
        <a
          href="https://proplogai.com/login"
          class="relative inline-flex px-7 py-3 rounded-xl bg-gradient-brand text-[#08080f] text-sm font-semibold hover:shadow-lg hover:shadow-violet/25 transition-all duration-300 hover:-translate-y-0.5"
        >
          Start Free Trading Journal
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tag-option {
    color: rgba(255, 255, 255, 0.45);
  }
  .tag-option:hover {
    background: rgba(167, 139, 250, 0.06);
    color: rgba(255, 255, 255, 0.8);
  }
  .tag-option.active {
    background: rgba(167, 139, 250, 0.1);
    color: #a78bfa;
  }

  .blog-post-item {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .blog-post-item.hidden-by-filter {
    display: none;
  }
</style>

<script>
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  const dropdownBtn = document.getElementById('tag-dropdown-btn');
  const dropdownMenu = document.getElementById('tag-dropdown-menu');
  const dropdownLabel = document.getElementById('tag-dropdown-label');
  const chevron = document.getElementById('tag-chevron');
  const tagOptions = document.querySelectorAll('.tag-option');
  const postItems = document.querySelectorAll('.blog-post-item');
  const resultCount = document.getElementById('result-count');
  const noResults = document.getElementById('no-results');
  const postsGrid = document.getElementById('posts-grid');
  const clearBtn = document.getElementById('clear-filters');

  let activeTag = 'all';
  let searchQuery = '';
  let menuOpen = false;

  function toggleMenu(open?: boolean) {
    menuOpen = open !== undefined ? open : !menuOpen;
    dropdownMenu?.classList.toggle('hidden', !menuOpen);
    chevron?.classList.toggle('rotate-180', menuOpen);
  }

  // Toggle dropdown
  dropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleMenu();
  });

  // Close on outside click
  document.addEventListener('click', () => toggleMenu(false));
  dropdownMenu?.addEventListener('click', (e) => e.stopPropagation());

  function filterPosts() {
    let visible = 0;

    postItems.forEach((item) => {
      const el = item as HTMLElement;
      const tags = el.dataset.tags || '';
      const title = el.dataset.title || '';
      const description = el.dataset.description || '';

      const matchesTag = activeTag === 'all' || tags.split(',').includes(activeTag);
      const matchesSearch = !searchQuery ||
        title.includes(searchQuery) ||
        description.includes(searchQuery) ||
        tags.toLowerCase().includes(searchQuery);

      if (matchesTag && matchesSearch) {
        el.classList.remove('hidden-by-filter');
        visible++;
      } else {
        el.classList.add('hidden-by-filter');
      }
    });

    if (resultCount) {
      resultCount.textContent = `${visible} ${visible === 1 ? 'post' : 'posts'}`;
    }

    if (noResults) noResults.classList.toggle('hidden', visible > 0);
    if (postsGrid) postsGrid.classList.toggle('hidden', visible === 0);

    if (clearBtn) {
      clearBtn.classList.toggle('hidden', activeTag === 'all' && !searchQuery);
    }
  }

  // Tag option click
  tagOptions.forEach((opt) => {
    opt.addEventListener('click', () => {
      tagOptions.forEach((o) => o.classList.remove('active'));
      opt.classList.add('active');
      activeTag = (opt as HTMLElement).dataset.tag || 'all';
      if (dropdownLabel) {
        dropdownLabel.textContent = activeTag === 'all' ? 'All Topics' : activeTag.charAt(0).toUpperCase() + activeTag.slice(1);
      }
      toggleMenu(false);
      filterPosts();
    });
  });

  // Search handler
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    filterPosts();
  });

  // Clear handler
  clearBtn?.addEventListener('click', () => {
    activeTag = 'all';
    searchQuery = '';
    if (searchInput) searchInput.value = '';
    if (dropdownLabel) dropdownLabel.textContent = 'All Topics';
    tagOptions.forEach((o) => {
      o.classList.remove('active');
      if ((o as HTMLElement).dataset.tag === 'all') o.classList.add('active');
    });
    filterPosts();
  });
</script>
